# Stripe 支付密钥（测试环境）
# 从 Stripe Dashboard 获取: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_你的公钥
STRIPE_SECRET_KEY=sk_test_你的私钥

# 正式环境使用生产密钥
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_你的公钥
# STRIPE_SECRET_KEY=sk_live_你的私钥

# 网站域名（用于支付回调）
NEXT_PUBLIC_APP_URL=https://你的域名.vercel.app

# 腾讯云 LKEAP Coding Plan
# 从腾讯云控制台获取: https://console.cloud.tencent.com/lkeap
LKEAP_API_KEY=sk-sp-你的腾讯云API密钥
